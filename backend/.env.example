# Health Assistant - Environment Configuration

# API Security
API_KEY=your-secret-api-key-here-change-in-production

# LLM Provider (choose one)
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (alternative)
# GOOGLE_API_KEY=your-google-api-key
# GEMINI_MODEL=gemini-2.0-flash

# Database
DATABASE_URL=sqlite:///./health_assistant.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/health_assistant

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
